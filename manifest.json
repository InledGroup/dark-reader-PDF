{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "4.2.1",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "alarms",
    "notifications",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "__MSG_actionTitle__",
    "default_icon": {
      "16": "icons/darkreaderpdf.png",
      "48": "icons/darkreaderpdf.png",
      "128": "icons/darkreaderpdf.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "icons": {
    "16": "icons/darkreaderpdf.png",
    "48": "icons/darkreaderpdf.png",
    "128": "icons/darkreaderpdf.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "pdfjs/web/viewer.html",
        "pdfjs/web/viewer.css",
        "pdfjs/web/viewer.mjs",
        "pdfjs/web/check-updates-viewer.js",
        "pdfjs/build/pdf.mjs",
        "pdfjs/build/pdf.worker.mjs",
        "pdfjs/web/images/*",
        "pdfjs/web/locale/*",
        "pdfjs/web/standard_fonts/*",
        "pdfjs/web/cmaps/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}