{
  "manifest_version": 3,
  "name": "Dark PDF Viewer Pro",
  "version": "3.0.0",
  "description": "Visualizador de PDF oficial con barra de herramientas en modo oscuro.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Abrir en modo oscuro"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["**/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
