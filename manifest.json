{
  "manifest_version": 3,
  "name": "Dark PDF Viewer Pro",
  "version": "4.1.1",
  "description": "Visualizador de PDF oficial con tema oscuro nativo.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Abrir en modo oscuro",
    "default_icon": {
      "16": "icons/darkreaderpdf.png",
      "48": "icons/darkreaderpdf.png",
      "128": "icons/darkreaderpdf.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "icons": {
    "16": "icons/darkreaderpdf.png",
    "48": "icons/darkreaderpdf.png",
    "128": "icons/darkreaderpdf.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "pdfjs/web/viewer.html",
        "pdfjs/web/viewer.css",
        "pdfjs/web/viewer.mjs",
        "pdfjs/build/pdf.mjs",
        "pdfjs/build/pdf.worker.mjs",
        "pdfjs/web/images/*",
        "pdfjs/web/locale/*",
        "pdfjs/web/standard_fonts/*",
        "pdfjs/web/cmaps/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}